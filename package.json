{
  "name": "pixelmapper",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "concurrently -n nuxt,canvas,core -c cyan,yellow,green \"nuxt dev\" \"cargo watch -C rs-engine/canvas -s 'wasm-pack build --target web --out-dir ../../node_modules/rs-engine-canvas'\" \"cargo watch -C rs-engine/core -s 'wasm-pack build --target web --out-dir ../../node_modules/rs-engine-core'\"",
    "dev:nuxt": "nuxt dev",
    "dev:wasm:canvas": "cargo watch -C rs-engine/canvas -s 'wasm-pack build --target web --out-dir ../../node_modules/rs-engine-canvas'",
    "dev:wasm:core": "cargo watch -C rs-engine/core -s 'wasm-pack build --target web --out-dir ../../node_modules/rs-engine-core'",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && ./scripts/setup-ofl.sh",
    "release": "bun run scripts/release.ts"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esptool-js": "^0.5.7",
    "lucide-vue-next": "^0.575.0",
    "nuxt": "^4.3.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.8.2",
    "rs-engine-canvas": "./rs-engine/canvas/pkg",
    "rs-engine-core": "./rs-engine/core/pkg",
    "shadcn-nuxt": "2.4.3",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@itmr.dev/bump": "^1.5.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^25.3.1",
    "@types/w3c-web-serial": "^1.0.8",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  },
  "version": "0.1.10"
}
